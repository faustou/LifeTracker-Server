# URL del proyecto en Supabase
# Settings > API > Project URL
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave service_role de Supabase (secreta, nunca exponer en el cliente)
# Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_KEY=eyJ...

# Puerto del servidor (Render lo inyecta automaticamente, no hace falta setearlo ahi)
PORT=3001

# URL del cliente en produccion (para CORS)
# Ej: https://lifetracker.vercel.app
CLIENT_URL=https://tu-app.vercel.app
